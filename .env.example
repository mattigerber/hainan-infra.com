# Public client-side environment variables
# Anything prefixed with NEXT_PUBLIC_ is exposed to the browser.

# Application base URL (used for metadata/canonical URLs)
NEXT_PUBLIC_SITE_URL=https://hainan-infra.com

# WalletConnect Cloud project id (required in browser for WalletConnect)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Mainnet RPC endpoints (server-only; not exposed to browser)
POCKET_RPC=
LAVA_RPC=

# Optional contract address used by ticket sale UI
NEXT_PUBLIC_TICKET_SALE_CONTRACT_ADDRESS=

# Server runtime settings for server.js
PORT=3000
HOSTNAME=0.0.0.0
